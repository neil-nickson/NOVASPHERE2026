0:["FI8j6fqtLIKzlWIEOS7BC",[[["",{"children":["code-of-conduct",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",{"children":["code-of-conduct",{"children":["__PAGE__",{},[["$L1",["$","section",null,{"className":"rounded-3xl border border-purple-500/30 bg-black/45 px-8 py-12 md:px-12 md:py-14","children":["$","div",null,{"className":"mx-auto max-w-4xl space-y-6","children":[["$","h1",null,{"className":"text-3xl font-semibold tracking-tight text-purple-300 md:text-4xl","children":"NovaSphere Code of Conduct"}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"NovaSphere is built on mutual respect, inclusivity, integrity, and a shared passion for innovation. To maintain a positive, safe, and productive environment, this Code of Conduct applies to everyone involved in the event, including participants, organisers, mentors, judges, volunteers, sponsors, and guests. It governs behaviour during all in-person activities as well as across digital platforms connected to NovaSphere."}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"Everyone is expected to act in a professional, respectful, and responsible manner at all times. Whether collaborating within a team, engaging in a debate, presenting an idea, or communicating online, your words and actions should reflect kindness, openness, and consideration for others. We value clear communication, active listening, and constructive feedback. Healthy disagreements are natural in innovation-driven spaces, but they must always be handled with maturity and respect."}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"NovaSphere welcomes individuals from diverse educational, cultural, social, and personal backgrounds. We believe diversity strengthens creativity and innovation. Every participant has the right to feel safe, included, and valued regardless of their gender, gender identity, sexual orientation, race, ethnicity, nationality, religion, disability, appearance, or beliefs. Discrimination, exclusion, or biased behaviour of any kind will not be tolerated."}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"Harassment in any form is strictly prohibited. This includes inappropriate comments, unwanted advances, offensive jokes, intimidation, bullying, disruptive conduct, or any verbal, physical, or online abuse. Harassment may occur in person or through digital communication channels such as messaging groups, emails, or social media. If anyone experiences or witnesses such behaviour, they are encouraged to report it immediately to the organising team."}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"The NovaSphere organising committee takes all reports seriously and will handle them in a confidential, fair, and respectful manner. Appropriate action may include a warning, removal from a session, disqualification from competitions, or removal from the event entirely, depending on the severity of the situation. The safety and well-being of participants remain our highest priority."}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"Integrity is a core value of NovaSphere. Participants are expected to uphold academic and professional honesty. Plagiarism, idea theft, unfair collaboration, cheating, or misrepresentation of work will not be tolerated and may result in immediate disqualification. We encourage original thinking, ethical innovation, and proper acknowledgment of sources wherever necessary."}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"Collaboration and community spirit define NovaSphere. We encourage sharing knowledge, supporting fellow participants, and fostering an environment where everyone can grow. By participating in NovaSphere, you agree to follow this Code of Conduct and contribute positively to the experience. Together, we can ensure NovaSphere remains a space where ideas thrive, respect is foundational, and every individual feels empowered to innovate and excel."}]]}]}],null],null],null]},[null,["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children","code-of-conduct","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/80af5d4f46db1e11.css","precedence":"next","crossOrigin":"$undefined"}]],["$","html",null,{"lang":"en","className":"dark","children":["$","body",null,{"className":"__className_f367f3","children":["$","$L4",null,{"children":["$","div",null,{"className":"min-h-dvh","children":[["$","$L5",null,{}],["$","main",null,{"className":"mx-auto w-full max-w-6xl px-4 py-8","children":["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWe