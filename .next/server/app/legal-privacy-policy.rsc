0:["8AHg8vTfjKQzGQzVsIAfJ",[[["",{"children":["legal-privacy-policy",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",{"children":["legal-privacy-policy",{"children":["__PAGE__",{},[["$L1",["$","section",null,{"className":"rounded-3xl border border-purple-500/30 bg-black/45 px-8 py-12 md:px-12 md:py-14","children":["$","div",null,{"className":"mx-auto max-w-4xl space-y-6","children":[["$","h1",null,{"className":"text-3xl font-semibold tracking-tight text-purple-300 md:text-4xl","children":"NovaSphere Legal & Privacy Policy"}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"At NovaSphere, we are committed to protecting your personal information and maintaining transparency in how it is collected, used, and safeguarded. This section outlines how your data is handled when you participate in NovaSphere events, platforms, and related activities. When you register for NovaSphere, you entrust us with your personal information, and we take that responsibility seriously by ensuring it is managed securely, ethically, and in accordance with applicable laws and regulations."}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"During registration and participation, we may collect details such as your full name, phone number, email address, institution or workplace, team information, and any project materials or submissions you provide. This information is used strictly for event-related purposes, including managing registrations, forming teams, assigning mentors or judges, communicating updates, evaluating submissions, issuing certificates, and maintaining official records of participation."}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"NovaSphere does not sell, rent, or trade personal information with external organisations unrelated to the event. In limited cases, relevant information may be shared with authorised mentors, judges, or event partners when necessary for evaluation or coordination purposes, and only within the scope of the event. All data is stored using secure systems accessible only to authorised members of the organising team."}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"Photographs, videos, recordings, and other media captured during NovaSphere activities may be used for official promotional purposes, including publication on websites, social media platforms, brochures, and event highlight materials. By participating, you consent to the possible use of such media. However, if you prefer not to appear in promotional content, you may inform the organising team in advance, and reasonable efforts will be made to respect your request."}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"Participants have the right to request access to their personal data, correct inaccuracies, or request deletion after the event concludes. Such requests can be made through official NovaSphere contact channels and will be addressed in a timely and respectful manner."}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"All registration fees paid for NovaSphere are strictly non-refundable. Once payment is completed, no refunds will be issued under any circumstances, including non-attendance, withdrawal, or disqualification. By registering, participants acknowledge and agree to this refund policy."}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"We strongly advise participants not to share sensitive personal information on public platforms, group chats, or open discussions during the event. While NovaSphere takes reasonable steps to maintain a secure and respectful environment, participants also share responsibility in protecting their own information."}],["$","p",null,{"className":"text-base leading-relaxed text-white/80","children":"By taking part in NovaSphere, you agree to the terms outlined in this Legal and Privacy Policy. We value your trust and remain committed to maintaining a transparent, responsible, and secure environment for all participants."}]]}]}],null],null],null]},[null,["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children","legal-privacy-policy","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/1e182ff62104f08e.css","precedence":"next","crossOrigin":"$undefined"}]],["$","html",null,{"lang":"en","className":"dark","children":["$","body",null,{"className":"__className_f367f3","children":["$","$L4",null,{"children":["$","div",null,{"className":"min-h-dvh","children":[["$","$L5",null,{}],["$","main",null,{"className":"mx-auto w-full max-w-6xl px-4 py-8","children":["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"